# Configuration Monitoring
DOMAIN={{ domain }}

GRAFANA_ADMIN_USER={{ admin_user | default('admin') }}
GRAFANA_ADMIN_PASSWORD={{ vault.grafana.admin_password }}

PROXMOX_HOST={{ proxmox.endpoint | regex_replace('https://(.*):8006/.*', '\\1') }}
PVE_USER={{ pve_user | default('prometheus1@pve') }}
PVE_TOKEN_NAME={{ pve_token_name | default('pve_exporter') }}
PVE_TOKEN_VALUE={{ vault.pve_exporter.token_value }}

# ca peut se remplir très très vite, si le stockage est faible mettre 1 à 2 jours max
PROMETHEUS_RETENTION={{ prometheus_retention | default('3d') }}
LOKI_RETENTION={{ loki_retention | default('3d') }}
