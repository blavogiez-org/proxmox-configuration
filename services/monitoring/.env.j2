# Configuration Monitoring
DOMAIN={{ domain }}

GRAFANA_ADMIN_USER={{ admin_user }}
GRAFANA_ADMIN_PASSWORD={{ vault.grafana_admin_password }}

PROXMOX_HOST={{ proxmox.endpoint | regex_replace('https://(.*):8006/.*', '\\1') }}
PVE_USER=prometheus@pve
PVE_TOKEN_NAME=pve-exporter
PVE_TOKEN_VALUE={{ vault.pve_exporter_token_value }}

PROMETHEUS_RETENTION=15d
LOKI_RETENTION=15d
