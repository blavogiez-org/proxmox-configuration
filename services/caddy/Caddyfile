(site_rate_limit) {
    rate_limit {
        zone {args[0]} {
            key {client_ip}
            events {args[1]}
            window 1m
            ipv6_prefix 64
        }
    }
}


{
  auto_https off
}

import /etc/caddy/sites/*.conf
